{
  "manifest_version": 3,
  "default_locale": "zh_TW",
  "name": "__MSG_extName__",
  "version": "4.5.2",
  "key": "",
  "description": "__MSG_extDesc__",
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "web_accessible_resources": [{
    "resources": [
      "content/sse-parser.js",
      "content/censor-xhr-hook.js",
      "content/prevent-auto-scroll.js"
    ],
    "matches": ["*://chat.deepseek.com/*"]
  }],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.deepseek.com/*"
      ],
      "js": [
        "utils/i18n.js",
        "utils/storage-manager.chunking.js",
        "utils/storage-manager.lock.js",
        "utils/storage-manager.sync.js",
        "utils/storage-manager.presets.js",
        "utils/storage-manager.js",
        "content/sidebar-auto-hide.js",
        "content/chat-width.js",
        "content/input-width.js",
        "content/hide-thinking.js",
        "content/censor-reply-restore.markdown.js",
        "content/censor-reply-restore.dom.js",
        "content/censor-reply-restore.storage.js",
        "content/censor-reply-restore.js",
        "content/prevent-auto-scroll-bridge.js",
        "content/harvest.js",
        "content/content-script.export.js",
        "content/preset-dropdown.position.js",
        "content/preset-dropdown.component.js",
        "content/preset-overlay.styles.js",
        "content/preset-overlay.resolvers.js",
        "content/preset-settle.scheduler.js",
        "content/preset-overlay.controller.js",
        "content/temporary-chat-constants.js",
        "content/content-script.js",
        "content/temporary-chat-delete-api.js",
        "content/temporary-chat-delete.js",
        "content/temporary-chat-toggle.js",
        "content/edit-message-cleanup.js",
        "content/quote-reply.js",
        "content/go-top.locate.js",
        "content/go-top.render.js",
        "content/go-top.scroll.js",
        "content/go-top.js",
        "content/mobile-sidebar-swipe.js",
        "content/mobile-homepage-cleanup.js"
      ],
      "css": ["content/censor-reply-restore.css", "content/go-top.css", "content/preset-dropdown.css", "content/temporary-chat-toggle.css"],
      "run_at": "document_end"
    }
  ]
}
